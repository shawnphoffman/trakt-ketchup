# Copy to .env and fill in. Register an app at https://trakt.tv/oauth/applications
#
# Use .env (NOT .env.local): `vercel dev`'s serverless function runtime reads
# .env, while Vite reads .env too — so a single .env serves both the browser
# build and the /api OAuth proxy. Splitting them starves the function of the
# client secret (500 server_misconfigured). .env is gitignored.
#
# The Client ID is public (sent as the trakt-api-key header from the browser).
VITE_TRAKT_CLIENT_ID=

# The Client Secret is SERVER-ONLY. It is read by the Vercel function in /api
# and must never be exposed to the browser (no VITE_ prefix).
TRAKT_CLIENT_SECRET=

# Must exactly match the Redirect URI registered in your Trakt app.
# Dev:  http://localhost:3000
# Prod: https://your-app.vercel.app
VITE_TRAKT_REDIRECT_URI=http://localhost:3000
