{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "vercel dev (full app + /api)",
      "runtimeExecutable": "vercel",
      "runtimeArgs": ["dev", "--listen", "3000"],
      "port": 3000
    },
    {
      "name": "vite (SPA only, no /api)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173
    },
    {
      "name": "vite preview (serves dist build)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "preview"],
      "port": 4173
    }
  ]
}
